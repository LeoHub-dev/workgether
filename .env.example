# Supabase → Project Settings → API
# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Project API keys → service_role secret (Reveal to copy)
# Server-only: never expose in the browser or commit this value
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32+ character secret for signing session cookies (jose)
AUTH_SECRET=change-me-to-a-long-random-string

# Optional: "yjs" (default) or "soft" for debounced autosave + postgres_changes
NEXT_PUBLIC_COLLAB_MODE=yjs
