# --- Cloud Supabase: Project Settings → API ---
# --- Local Supabase: `npx supabase status` after `npx supabase start` ---

# Project URL (local default: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role secret (Reveal to copy) — server-only, never commit
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32+ character secret for signing session cookies (jose)
AUTH_SECRET=change-me-to-a-long-random-string

# Optional: "yjs" (default) or "soft" for debounced autosave + postgres_changes
# Soft sync is simpler for local-first testing without Realtime quirks:
# NEXT_PUBLIC_COLLAB_MODE=soft
NEXT_PUBLIC_COLLAB_MODE=yjs
