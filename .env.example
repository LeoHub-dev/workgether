# --- Cloud Supabase: Project Settings → API ---
# --- Local Supabase: `npx supabase status` after `npx supabase start` ---

# Project URL (local default: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role secret (Reveal to copy) — server-only, never commit
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32+ character secret for signing session cookies (jose)
AUTH_SECRET=change-me-to-a-long-random-string

# Collaboration mode: "soft" (default, content_json is source of truth on reload)
# or "yjs" for CRDT live editing. Soft is recommended for reliable save/reopen.
NEXT_PUBLIC_COLLAB_MODE=soft
